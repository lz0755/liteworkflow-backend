<?xml version="1.0" encoding="UTF-8"?>
<included>
    <conversionRule conversionWord="safeMsg"
                    class="com.liteworkflow.common.core.logging.SanitizedMessageConverter"/>
    <conversionRule conversionWord="safeEx"
                    class="com.liteworkflow.common.core.logging.SanitizedThrowableProxyConverter"/>

    <property name="LOG_BASE_DIR" value="${LOG_DIR:-logs}"/>
    <property name="LOG_MAX_FILE_SIZE" value="${LOG_MAX_FILE_SIZE:-10MB}"/>
    <property name="LOG_ERROR_MAX_FILE_SIZE" value="${LOG_ERROR_MAX_FILE_SIZE:-10MB}"/>
    <property name="LOG_MAX_HISTORY" value="${LOG_MAX_HISTORY:-14}"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="${LOG_TOTAL_SIZE_CAP:-256MB}"/>
    <property name="LOG_ERROR_TOTAL_SIZE_CAP" value="${LOG_ERROR_TOTAL_SIZE_CAP:-64MB}"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level serviceName=${SERVICE_NAME} traceId=%X{traceId:-} userId=%X{userId:-} eventId=%X{eventId:-} workspaceId=%X{workspaceId:-} projectId=%X{projectId:-} requestMethod=%X{requestMethod:-} requestPath=%X{requestPath:-} status=%X{status:-} latencyMs=%X{latencyMs:-} thread=%thread logger=%logger{40} - %safeMsg%n%safeEx"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="APPLICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_BASE_DIR}/${SERVICE_NAME}/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_BASE_DIR}/${SERVICE_NAME}/archive/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_BASE_DIR}/${SERVICE_NAME}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_BASE_DIR}/${SERVICE_NAME}/archive/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_ERROR_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_ERROR_TOTAL_SIZE_CAP}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>
</included>
