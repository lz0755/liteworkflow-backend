#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/app-common.sh
source "${SCRIPT_DIR}/lib/app-common.sh"

services=(gateway-service ai-service infra-service identity-service core-service)
for service in "${services[@]}"; do
  pid_file="${APP_RUN_DIR}/${service}.pid"
  [[ -f "${pid_file}" ]] || continue
  pid="$(<"${pid_file}")"
  if kill -0 "${pid}" 2>/dev/null; then
    echo "Stopping ${service} (PID ${pid})..."
    kill "${pid}"
    for _ in {1..30}; do
      kill -0 "${pid}" 2>/dev/null || break
      sleep 1
    done
    if kill -0 "${pid}" 2>/dev/null; then
      echo "WARN: ${service} did not stop within 30 seconds; PID ${pid} remains." >&2
      continue
    fi
  fi
  rm -f "${pid_file}"
done
