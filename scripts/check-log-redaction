#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_DIR="${LOG_DIR:-${ROOT_DIR}/logs}"
[[ -d "${LOG_DIR}" ]] || { echo "No runtime logs found; nothing to scan."; exit 0; }

pattern='Authorization:[[:space:]]*Bearer[[:space:]]+[A-Za-z0-9._~-]+|(^|[[:space:]])(password|accessToken|refreshToken|resetToken|apiKey|secretKey)=[^[][^[:space:]]+|[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'
mapfile -t files < <(find "${LOG_DIR}" -type f -name '*.log' -print)
failures=0
for file in "${files[@]}"; do
  if LC_ALL=C grep -Eq "${pattern}" "${file}"; then
    echo "FAIL possible sensitive value in ${file} (content suppressed)" >&2
    failures=$((failures + 1))
  fi
done
(( failures == 0 )) || { echo "Runtime log scan failed for ${failures} file(s)." >&2; exit 1; }
echo "Runtime log scan passed for ${#files[@]} file(s)."
