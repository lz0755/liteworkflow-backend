#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"
command -v rg >/dev/null 2>&1 || { echo "ERROR: ripgrep (rg) is required." >&2; exit 1; }

failures=0
scan_pattern() {
  local name="$1"
  local pattern="$2"
  local matches
  matches="$(rg --files-with-matches --hidden --glob '!scripts/check-secrets' \
    --glob '!docs/delivery/security-scan-report.md' --glob '!.git/**' "${pattern}" . 2>/dev/null || true)"
  if [[ -n "${matches}" ]]; then
    echo "FAIL ${name}: suspicious content in tracked file(s):" >&2
    printf '  %s\n' ${matches} >&2
    failures=$((failures + 1))
  else
    echo "PASS ${name}"
  fi
}

scan_pattern "private-key" '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
scan_pattern "openai-key" '(^|[^A-Za-z0-9])sk-[A-Za-z0-9_-]{20,}'
scan_pattern "aws-access-key" '(^|[^A-Z0-9])(AKIA|ASIA)[A-Z0-9]{16}([^A-Z0-9]|$)'
scan_pattern "github-token" '(ghp|github_pat)_[A-Za-z0-9_]{20,}'
scan_pattern "jwt-literal" 'JWT_SECRET=[A-Za-z0-9+/=]{32,}'

for key in POSTGRES_ADMIN_PASSWORD POSTGRES_PASSWORD REDIS_PASSWORD RABBITMQ_PASSWORD \
  JWT_SECRET INTERNAL_SERVICE_TOKEN NACOS_AUTH_TOKEN NACOS_ADMIN_PASSWORD \
  SEAWEEDFS_ACCESS_KEY SEAWEEDFS_SECRET_KEY LITEWORKFLOW_AI_API_KEY \
  LITEWORKFLOW_AI_EMBEDDING_API_KEY; do
  value="$(awk -v key="${key}" 'index($0, key "=") == 1 { print substr($0, length(key) + 2) }' .env.example)"
  if [[ "${value}" != replace_me* ]]; then
    echo "FAIL env-placeholder: ${key} must contain only a replace_me_* placeholder." >&2
    failures=$((failures + 1))
  fi
done

(( failures == 0 )) || { echo "Secret scan failed with ${failures} finding group(s)." >&2; exit 1; }
echo "Secret scan passed. Tracked and untracked non-ignored files were inspected; ignored local .env files were not read."
