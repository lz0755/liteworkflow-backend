# liteworkflow M0 local infrastructure
# Copy this file to .env and replace every replace_me_* value before starting.
# Keep .env local; never commit credentials generated for a real environment.

# Pinned, tested image tags (never use latest)
PGVECTOR_IMAGE_TAG=0.8.2-pg16-trixie
REDIS_IMAGE_TAG=8.2.7-alpine3.22
RABBITMQ_IMAGE_TAG=4.1.8-management-alpine
NACOS_IMAGE_TAG=v3.2.1
SEAWEEDFS_IMAGE_TAG=4.29
MAILHOG_IMAGE_TAG=v1.0.1

# PostgreSQL. The bootstrap administrator remains internal to the container;
# services must connect with the non-superuser POSTGRES_USER account.
POSTGRES_DB=liteworkflow_backend
POSTGRES_ADMIN_PASSWORD=replace_me_postgres_admin_password
POSTGRES_USER=liteworkflow
POSTGRES_PASSWORD=replace_me_postgres_app_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=replace_me_redis_password
REDIS_PORT=6379

# Gateway security and routing. JWT_SECRET must be Base64 for at least 32 random bytes.
JWT_SECRET=replace_me_with_base64_for_at_least_32_random_bytes
JWT_ISSUER=liteworkflow
IDENTITY_SERVICE_URL=http://localhost:8081
CORE_SERVICE_URL=http://localhost:8082
INFRA_SERVICE_URL=http://localhost:8083
AI_SERVICE_URL=http://localhost:8084
CORS_ALLOWED_ORIGINS=http://localhost:3000
LITEWORKFLOW_OPENAPI_ENABLED=true

# Direct OpenAI-compatible LLM API. Required whenever ai-service is not using the test profile.
# The base URL does not include /v1/chat/completions; Spring AI appends the API path.
LITEWORKFLOW_AI_BASE_URL=https://api.openai.com
LITEWORKFLOW_AI_API_KEY=replace_me_external_llm_api_key
LITEWORKFLOW_AI_CHAT_MODEL=replace_me_chat_model
LITEWORKFLOW_AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
# Embedding model and its actual output size are both required. There is deliberately no
# default dimension: changing either requires a new controlled vector migration/rebuild.
LITEWORKFLOW_AI_EMBEDDING_MODEL=replace_me_embedding_model
LITEWORKFLOW_AI_EMBEDDING_DIMENSIONS=replace_me_actual_embedding_dimensions
# Optional when chat and embeddings use different OpenAI-compatible endpoints/credentials.
LITEWORKFLOW_AI_EMBEDDING_BASE_URL=https://api.openai.com
LITEWORKFLOW_AI_EMBEDDING_API_KEY=replace_me_external_embedding_api_key
LITEWORKFLOW_AI_EMBEDDINGS_PATH=/v1/embeddings
LITEWORKFLOW_RAG_STARTUP_VALIDATION=true
LITEWORKFLOW_RAG_INITIALIZE_SCHEMA=false
LITEWORKFLOW_RAG_TOP_K=8
LITEWORKFLOW_RAG_SIMILARITY_THRESHOLD=0.72
LITEWORKFLOW_RAG_INDEX_MAX_ATTEMPTS=3
LITEWORKFLOW_RAG_INDEX_PROCESSING_LEASE=5m
LITEWORKFLOW_AI_CONNECT_TIMEOUT=10s
LITEWORKFLOW_AI_REQUEST_TIMEOUT=60s
LITEWORKFLOW_AI_MAX_OUTPUT_TOKENS=2000
LITEWORKFLOW_AI_MAX_CONCURRENT_STREAMS=4
LITEWORKFLOW_AI_STREAM_CONCURRENCY_ACQUIRE_TIMEOUT=50ms
LITEWORKFLOW_AI_STREAM_IDLE_TIMEOUT=60s
LITEWORKFLOW_AI_RETRY_MAX_ATTEMPTS=3
LITEWORKFLOW_AI_RETRY_INITIAL_INTERVAL=250ms
LITEWORKFLOW_AI_RETRY_MULTIPLIER=2
LITEWORKFLOW_AI_RETRY_MAX_INTERVAL=2s
LITEWORKFLOW_AI_MAX_CONCURRENT_REQUESTS=8
LITEWORKFLOW_AI_CONCURRENCY_ACQUIRE_TIMEOUT=100ms
LITEWORKFLOW_AI_DAILY_REQUEST_LIMIT=100
LITEWORKFLOW_AI_DAILY_TOKEN_LIMIT=200000

# RabbitMQ
RABBITMQ_USER=liteworkflow
RABBITMQ_PASSWORD=replace_me_rabbitmq_password
RABBITMQ_VHOST=liteworkflow_backend
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Nacos 3.x. NACOS_AUTH_TOKEN must be Base64 for at least 32 random bytes.
NACOS_AUTH_TOKEN=replace_me_with_base64_for_at_least_32_random_bytes
NACOS_AUTH_IDENTITY_KEY=replace_me_nacos_identity_key
NACOS_AUTH_IDENTITY_VALUE=replace_me_nacos_identity_value
NACOS_ADMIN_PASSWORD=replace_me_nacos_admin_password
NACOS_CONSOLE_PORT=8888
NACOS_CLIENT_PORT=8848
NACOS_GRPC_PORT=9848

# SeaweedFS S3 (single-container mini mode)
SEAWEEDFS_ACCESS_KEY=replace_me_seaweedfs_access_key
SEAWEEDFS_SECRET_KEY=replace_me_seaweedfs_secret_key
SEAWEEDFS_BUCKET=liteworkflow
SEAWEEDFS_S3_PORT=8333

# Application S3 adapter. For local SeaweedFS these values match the gateway above.
# For AWS S3 set S3_BUCKET/S3_REGION, S3_PATH_STYLE=false, leave S3_ENDPOINT empty,
# and use the standard AWS credential provider chain.
S3_BUCKET=liteworkflow
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:8333
S3_PATH_STYLE=true
INTERNAL_SERVICE_TOKEN=replace_me_internal_service_token

# MailHog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@liteworkflow.local
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_READ_TIMEOUT_MS=5000
SMTP_WRITE_TIMEOUT_MS=5000
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_DELAY=10s
EMAIL_BATCH_SIZE=25
EMAIL_DISPATCH_DELAY=5s
EMAIL_SCHEDULING_ENABLED=true
LITEWORKFLOW_WEB_BASE_URL=http://localhost:3000

# Basic M9 issue exports. CSV and XLSX are generated in bounded batches and
# staged in this temporary directory before their known-length S3 upload.
EXPORT_BATCH_SIZE=500
EXPORT_TEMP_DIRECTORY=/tmp/liteworkflow-exports
EXPORT_CONSUMER_MAX_ATTEMPTS=5
EXPORT_CONSUMER_INITIAL_INTERVAL=500ms
EXPORT_CONSUMER_RETRY_MULTIPLIER=2.0
EXPORT_CONSUMER_MAX_INTERVAL=5s
EXPORT_MAX_PUBLISH_ATTEMPTS=12
EXPORT_PUBLISH_RETRY_DELAY=10s
EXPORT_PUBLISHER_CONFIRM_TIMEOUT=5s
EXPORT_SCHEDULING_ENABLED=true

# Per-service rolling application/error logs. Files are written under
# LOG_DIR/<service-name>/ and both appenders enforce history and capacity caps.
LOG_DIR=logs
LOG_MAX_FILE_SIZE=10MB
LOG_ERROR_MAX_FILE_SIZE=10MB
LOG_MAX_HISTORY=14
LOG_TOTAL_SIZE_CAP=256MB
LOG_ERROR_TOTAL_SIZE_CAP=64MB
