# liteworkflow M0 local infrastructure
# Copy this file to .env and replace every replace_me_* value before starting.
# Keep .env local; never commit credentials generated for a real environment.

# Pinned, tested image tags (never use latest)
PGVECTOR_IMAGE_TAG=0.8.2-pg16-trixie
REDIS_IMAGE_TAG=8.2.7-alpine3.22
RABBITMQ_IMAGE_TAG=4.1.8-management-alpine
NACOS_IMAGE_TAG=v3.2.1
SEAWEEDFS_IMAGE_TAG=4.29
MAILHOG_IMAGE_TAG=v1.0.1

# PostgreSQL. The bootstrap administrator remains internal to the container;
# services must connect with the non-superuser POSTGRES_USER account.
POSTGRES_DB=liteworkflow_backend
POSTGRES_ADMIN_PASSWORD=replace_me_postgres_admin_password
POSTGRES_USER=liteworkflow
POSTGRES_PASSWORD=replace_me_postgres_app_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=replace_me_redis_password
REDIS_PORT=6379

# Gateway security and routing. JWT_SECRET must be Base64 for at least 32 random bytes.
JWT_SECRET=replace_me_with_base64_for_at_least_32_random_bytes
JWT_ISSUER=liteworkflow
IDENTITY_SERVICE_URL=http://localhost:8081
CORE_SERVICE_URL=http://localhost:8082
INFRA_SERVICE_URL=http://localhost:8083
AI_SERVICE_URL=http://localhost:8084
CORS_ALLOWED_ORIGINS=http://localhost:3000
LITEWORKFLOW_OPENAPI_ENABLED=true

# RabbitMQ
RABBITMQ_USER=liteworkflow
RABBITMQ_PASSWORD=replace_me_rabbitmq_password
RABBITMQ_VHOST=liteworkflow_backend
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Nacos 3.x. NACOS_AUTH_TOKEN must be Base64 for at least 32 random bytes.
NACOS_AUTH_TOKEN=replace_me_with_base64_for_at_least_32_random_bytes
NACOS_AUTH_IDENTITY_KEY=replace_me_nacos_identity_key
NACOS_AUTH_IDENTITY_VALUE=replace_me_nacos_identity_value
NACOS_ADMIN_PASSWORD=replace_me_nacos_admin_password
NACOS_CONSOLE_PORT=8888
NACOS_CLIENT_PORT=8848
NACOS_GRPC_PORT=9848

# SeaweedFS S3 (single-container mini mode)
SEAWEEDFS_ACCESS_KEY=replace_me_seaweedfs_access_key
SEAWEEDFS_SECRET_KEY=replace_me_seaweedfs_secret_key
SEAWEEDFS_BUCKET=liteworkflow
SEAWEEDFS_S3_PORT=8333

# MailHog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
