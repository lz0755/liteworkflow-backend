meta {
  name: 02 / Alice reads Project
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{aliceToken}}
}

tests {
  test("Alice can read the Project", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().code).to.equal("OK");
    expect(res.getBody().data.id).to.equal(bru.getVar("projectId"));
  });
}
