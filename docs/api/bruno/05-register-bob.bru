meta {
  name: 01 / Register Bob
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "bob.{{runId}}@demo.invalid",
    "displayName": "Bob",
    "password": "{{demoPassword}}"
  }
}

tests {
  test("Bob registration succeeds", function () {
    expect(res.getStatus()).to.equal(201);
    expect(res.getBody().code).to.equal("OK");
  });
}
