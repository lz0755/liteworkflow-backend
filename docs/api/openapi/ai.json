  "info": {
    "title": "liteworkflow ai API",
    "version": "v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/ai/assist": {
      "post": {
        "operationId": "assist",
        "parameters": [
          {
            "in": "query",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CurrentUser"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssistRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAssistResponse"
                }
              }
            },
            "description": "OK"
          }
        },
        "tags": [
          "ai-controller"
        ]
      }
    },
    "/api/v1/ai/assist/stream": {
      "post": {
        "operationId": "streamAssist",
        "parameters": [
          {
            "in": "query",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CurrentUser"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssistRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ServerSentEventAiStreamEventData"
                  },
                  "type": "array"
                }
              }
            },
            "description": "OK"
          }
        },
        "tags": [
          "ai-controller"
        ]
      }
    },
    "/api/v1/ai/conversations": {
      "get": {
        "operationId": "listConversations",
        "parameters": [
          {
            "in": "query",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/CurrentUser"
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "size",
            "required": false,
            "schema": {
              "default": 20,
              "format": "int32",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePageResultConversationSummaryResponse"
                }
              }
            },
            "description": "OK"
          }
        },
        "tags": [
          "ai-controller"
        ]
      }
    },
